# Copy to mobile/fastlane/.env and fill before running lanes (never commit .env)

# Apple
APPLE_ID=you@example.com
APPLE_TEAM_ID=XXXXXXXXXX
APP_STORE_CONNECT_TEAM_ID=XXXXXXXXXX
IOS_APP_IDENTIFIER=com.synapse.learning

# Optional — fastlane match signing repo
MATCH_GIT_URL=git@github.com:YOUR_ORG/synapse-ios-signing.git
MATCH_PASSWORD=your-match-encryption-password
MATCH_READONLY=true

# Android — path to Play Console service account JSON (also: mobile/fastlane/play-store-credentials.json)
# PLAY_STORE_JSON_KEY=./play-store-credentials.json

# Android release signing (gradle.properties or CI secrets)
# ANDROID_KEYSTORE_PATH=
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=
