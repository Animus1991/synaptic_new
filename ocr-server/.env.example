# ---------------------------------------------------------------------------
# Synapse local OCR server configuration
# Copy this file to `.env` and adjust. All values are optional; sensible
# defaults let the server run fully offline with Tesseract out of the box.
# ---------------------------------------------------------------------------

# HTTP port. The Synapse client defaults its proxy base to http://localhost:8787,
# so keeping 8787 means zero client configuration is required.
PORT=8787

# CORS allow-list. Comma-separated origins, or "*" to allow all (dev only).
CORS_ORIGIN=*

# Optional shared secret. When set, requests must send
# `Authorization: Bearer <token>` with a matching value; otherwise auth is open.
# OCR_AUTH_TOKEN=

# Default Tesseract languages (used when the request omits `languages`).
OCR_TESSERACT_LANGS=eng+ell

# Maximum number of pages processed per request (safety cap).
OCR_MAX_PAGES=15

# ---------------------------------------------------------------------------
# Vision-LLM engine (optional, recommended for Greek handwriting).
# When enabled, the server routes recognition to an OpenAI-compatible
# /chat/completions endpoint that accepts image inputs. This dramatically
# improves both printed and handwritten Greek quality.
#
# Works with: OpenAI (gpt-4o / gpt-4o-mini), Ollama (http://localhost:11434/v1,
# model e.g. qwen2.5-vl:7b / llama3.2-vision), vLLM, LM Studio, OpenRouter, etc.
# ---------------------------------------------------------------------------

# Turn the vision engine on. When false, only Tesseract is used.
OCR_VISION_ENABLED=false

# OpenAI-compatible base URL (must expose POST {base}/chat/completions).
OCR_VISION_BASE_URL=https://api.openai.com/v1

# API key for the vision endpoint (leave blank for local servers like Ollama).
OCR_VISION_API_KEY=

# Vision model id with image support.
OCR_VISION_MODEL=gpt-4o-mini

# Sampling temperature for transcription (low = faithful).
OCR_VISION_TEMPERATURE=0

# Per-request timeout for the vision endpoint (milliseconds).
OCR_VISION_TIMEOUT_MS=120000

# Engine selection strategy when the request `mode` is "auto":
#   vision-first  -> use vision when enabled, else Tesseract (best quality)
#   tesseract     -> always Tesseract for auto (vision only for mode=handwriting)
OCR_AUTO_STRATEGY=vision-first
