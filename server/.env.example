# --- Synapse Learning proxy configuration ---

# Port the proxy listens on.
PORT=8787

# Upstream OpenAI-compatible API (OpenAI, Azure OpenAI, OpenRouter, local vLLM…).
UPSTREAM_BASE_URL=https://api.openai.com/v1

# The provider key. Stays server-side and is NEVER sent to the browser.
OPENAI_API_KEY=sk-replace-me

# Secret used to sign account JWTs. Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-string
# Access token lifetime (JWT). Refresh tokens are opaque and stored server-side.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Per-account+IP requests per minute across all /v1/* routes.
RATE_LIMIT_RPM=120
# Max PDF/image pages processed per OCR request (server Tesseract).
OCR_MAX_PAGES=15
# Optional spaCy/Stanza NER sidecar (POST /entities). Example: http://localhost:8790
# NER_SERVICE_URL=http://localhost:8790

# Comma-separated list of allowed browser origins (CORS). Use * only in dev.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# When true, requests without an account token use a shared "anonymous" account
# (handy for local dev / the current client). Set false to require sign-in.
ALLOW_ANONYMOUS=true

# W1 — require email verification before PUT /v1/library and /v1/session.
# Defaults to true in production, false otherwise. Set explicitly to override.
# EMAIL_VERIFICATION_REQUIRED=false

# Optional: PostgreSQL for durable persistence (accounts, library, session sync).
# When unset, all stores are in-memory (lost on restart).
# DATABASE_URL=postgres://user:pass@localhost:5432/synapse
# Optional: Redis for distributed rate limiting + BullMQ vector indexing.
# REDIS_URL=redis://localhost:6379
# Run migrations automatically on server boot (default: true). Set false when using
# `npm run migrate` in CI/deploy with multiple app replicas.
# RUN_MIGRATIONS_ON_START=true

# Monthly token quota per plan (prompt + completion tokens).
FREE_MONTHLY_TOKEN_QUOTA=100000
PRO_MONTHLY_TOKEN_QUOTA=5000000
TEAM_MONTHLY_TOKEN_QUOTA=25000000

# Stripe billing (optional — enables POST /v1/billing/checkout)
# CLIENT_APP_URL=http://localhost:5173
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...

# --- Sprint L4: LTI 1.3 / SAML institutional pilot ---
# Canvas example issuer: https://canvas.instructure.com
# LTI_CLIENT_ID=your-tool-client-id-from-lms
# LTI_PLATFORM_AUTH_URL=https://your-lms.example.com/api/lti/authorize_redirect
# LTI_PLATFORM_ISSUER=https://your-lms.example.com
# LTI_AGS_TOKEN=platform-oauth-token-for-grade-passback
# LTI_AGS_TOKEN_URL=https://your-lms.example.com/login/oauth2/token
# LTI_AGS_CLIENT_ID=your-canvas-client-id
# LTI_AGS_CLIENT_SECRET=your-canvas-client-secret
# LTI_PLATFORM_JWKS_URL=https://your-lms.example.com/api/lti/security/jwks
# SAML_ENTITY_ID=https://your-synapse.example.com/v1/auth/saml/metadata
# SAML_IDP_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# SAML_ORG_ID=org_default_for_jit_membership
# SAML_DEFAULT_ROLE=student

