# Client (Vite) — optional observability
# When set, chunk-load errors are forwarded via @sentry/react (see docs/observability/sentry-chunk-errors.md)
VITE_SENTRY_DSN=

# Dashboard import (npm run sentry:import-dashboard) — server-side only, never commit tokens
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
