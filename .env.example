# Client (Vite) — optional observability
# When set, chunk-load errors are forwarded via @sentry/react (see docs/observability/sentry-chunk-errors.md)
VITE_SENTRY_DSN=
# Optional: Synapse proxy origin in production (defaults to same-origin + Vite dev proxy)
# VITE_API_ORIGIN=http://localhost:8787
# Public site URL for legal links (defaults to https://app.synapse-learning.io)
# VITE_PUBLIC_SITE_URL=https://app.synapse-learning.io
# Optional: self-hosted Jitsi domain (defaults to meet.jit.si)
# VITE_JITSI_DOMAIN=meet.jit.si

# AI-05 NotebookLM parity surfaces (Agent nav, library synthesis)
# Explicit true|false wins. If unset: ON in Vite DEV, OFF in production builds.
# Local override also available in Settings → Developer.
# VITE_SHOW_NOTEBOOKLM_PARITY=true

# Dashboard import (npm run sentry:import-dashboard) — server-side only, never commit tokens
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
