{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck --prefix server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test e2e/a11y-lesson-dock.spec.ts e2e/a11y-multi-viewport.spec.ts e2e/a11y-workspace-panels.spec.ts",
    "test:e2e:chunk-recovery": "playwright test e2e/chunk-failure-recovery.spec.ts e2e/chunk-failure-flows.spec.ts",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:visual:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "test:e2e:perf": "playwright test e2e/workspace-perf-budget.spec.ts",
    "test:e2e:perf:prod": "playwright test e2e/workspace-perf-budget.spec.ts --config playwright.prod.config.ts",
    "b11:stretch-tracker": "vite-node scripts/b11ProdStretchTracker.ts",
    "eval": "vitest run src/eval",
    "doc-lint": "node scripts/doc-lint.mjs",
    "i18n-lint": "node scripts/i18n-lint.mjs",
    "i18n-lint:update": "node scripts/i18n-lint.mjs --update",
    "sentry:import-dashboard": "node scripts/sentry-import-dashboard.mjs",
    "reprocess:stale": "vitest run src/cli/bulkReprocessStale.test.ts --no-file-parallelism",
    "build": "npm run typecheck:all && vite build",
    "build:fast": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "postinstall": "node scripts/copy-pyodide.mjs"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/nunito-sans": "^5.2.7",
    "@fontsource/playfair-display": "^5.2.8",
    "@hocuspocus/provider": "^4.3.0",
    "@huggingface/transformers": "^4.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/react": "^9.47.1",
    "@uiw/react-codemirror": "^4.25.10",
    "clsx": "2.1.1",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.9.0",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^4.10.38",
    "pyodide": "^0.26.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-resizable-panels": "^4.11.2",
    "tailwind-merge": "3.4.0",
    "tesseract.js": "^5.1.1",
    "ts-fsrs": "^5.4.1",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/katex": "^0.16.8",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "^3.2.4"
  }
}
